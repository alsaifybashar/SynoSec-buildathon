{
  "name": "@synosec/connector",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "rm -rf dist tsconfig.tsbuildinfo && pnpm --filter @synosec/contracts build && tsc -p tsconfig.json",
    "typecheck": "pnpm --filter @synosec/contracts build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "pnpm --filter @synosec/contracts build && vitest run --config vitest.unit.config.ts",
    "test:integration": "pnpm --filter @synosec/contracts build && vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@synosec/contracts": "workspace:*",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.3",
    "vitest": "^3.1.2"
  }
}
