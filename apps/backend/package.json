{
  "name": "@synosec/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run prisma:generate && tsx watch src/main.ts",
    "build": "pnpm run prisma:generate && tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "typecheck": "pnpm run prisma:generate && tsc -p tsconfig.json --noEmit",
    "test": "pnpm run prisma:generate && vitest run",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@prisma/client": "^6.7.0",
    "@synosec/contracts": "workspace:*",
    "ai": "^6.0.168",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "jose": "^6.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "prisma": "^6.19.3",
    "supertest": "^7.1.4",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.3",
    "vitest": "^3.1.2"
  }
}
