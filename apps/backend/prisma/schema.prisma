generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationEnvironment {
  production
  staging
  development
}

enum ApplicationStatus {
  active
  investigating
  archived
}

enum ExecutionConstraintKind {
  provider_policy
  legal_scope
  workflow_gate
}

enum AiAgentStatus {
  draft
  active
  archived
}

enum AiToolSource {
  system
  custom
}

enum AiToolStatus {
  active
  inactive
  missing
  manual
}

enum WorkflowStatus {
  draft
  active
  archived
}

enum WorkflowRunStatus {
  pending
  running
  completed
  failed
}

enum WorkflowTraceEntryStatus {
  completed
  failed
}

enum WorkflowTraceEventType {
  stage_started
  system_message
  agent_input
  model_decision
  tool_call
  tool_result
  verification
  finding_reported
  stage_result_submitted
  stage_contract_validation_failed
  agent_summary
  stage_completed
  stage_failed
  run_completed
  run_failed
}

enum WorkflowTraceEventStatus {
  pending
  running
  completed
  failed
}

enum ScanRunStatus {
  pending
  running
  complete
  aborted
}

enum ScanTacticStatus {
  pending
  in_progress
  complete
  skipped
}

model Application {
  id            String                 @id @db.Uuid
  name          String
  baseUrl       String?                @map("base_url")
  environment   ApplicationEnvironment
  status        ApplicationStatus
  lastScannedAt DateTime?              @map("last_scanned_at")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")
  workflows     Workflow[]
  workflowRuns  WorkflowRun[]
  constraintBindings ApplicationConstraintBinding[]

  @@index([name])
  @@index([status, environment])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([lastScannedAt])
  @@map("applications")
}

model ExecutionConstraint {
  id                          String                   @id
  name                        String
  kind                        ExecutionConstraintKind
  provider                    String?
  version                     Int                      @default(1)
  description                 String?
  bypassForLocalTargets       Boolean                  @default(false) @map("bypass_for_local_targets")
  denyProviderOwnedTargets    Boolean                  @default(false) @map("deny_provider_owned_targets")
  requireVerifiedOwnership    Boolean                  @default(false) @map("require_verified_ownership")
  allowActiveExploit          Boolean                  @default(false) @map("allow_active_exploit")
  requireRateLimitSupport     Boolean                  @default(false) @map("require_rate_limit_support")
  rateLimitRps                Int?                     @map("rate_limit_rps")
  requireHostAllowlistSupport Boolean                  @default(false) @map("require_host_allowlist_support")
  requirePathExclusionSupport Boolean                  @default(false) @map("require_path_exclusion_support")
  documentationUrls           String[]                 @default([]) @map("documentation_urls")
  excludedPaths               String[]                 @default([]) @map("excluded_paths")
  createdAt                   DateTime                 @default(now()) @map("created_at")
  updatedAt                   DateTime                 @updatedAt @map("updated_at")
  bindings                    ApplicationConstraintBinding[]

  @@index([kind, provider])
  @@map("execution_constraints")
}

model ApplicationConstraintBinding {
  applicationId String              @map("application_id") @db.Uuid
  constraintId  String              @map("constraint_id")
  createdAt     DateTime            @default(now()) @map("created_at")
  application   Application         @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  constraint    ExecutionConstraint @relation(fields: [constraintId], references: [id], onDelete: Cascade)

  @@id([applicationId, constraintId])
  @@index([constraintId])
  @@map("application_constraint_bindings")
}

model AiAgent {
  id             String          @id @db.Uuid
  name           String
  status         AiAgentStatus
  description    String?
  systemPrompt   String          @map("system_prompt")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  tools          AiAgentTool[]
  workflowStages WorkflowStage[]

  @@index([name])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("ai_agents")
}

model AiTool {
  id           String        @id
  name         String
  status       AiToolStatus
  source       AiToolSource
  description  String?
  adapter      String?
  binary       String?
  category     String
  riskTier     String        @map("risk_tier")
  notes        String?
  inputSchema  Json          @map("input_schema")
  outputSchema Json          @map("output_schema")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  agents       AiAgentTool[]

  @@index([name])
  @@index([status, source, category])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("ai_tools")
}

model AiAgentTool {
  agentId String  @map("agent_id") @db.Uuid
  toolId  String  @map("tool_id")
  ord     Int
  agent   AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tool    AiTool  @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@id([agentId, toolId])
  @@index([toolId])
  @@map("ai_agent_tools")
}

model Workflow {
  id            String               @id @db.Uuid
  name          String
  status        WorkflowStatus
  executionKind String               @default("workflow") @map("execution_kind")
  description   String?
  applicationId String?              @map("application_id") @db.Uuid
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  application   Application?         @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  stages        WorkflowStage[]
  launches      WorkflowLaunch[]
  runs          WorkflowRun[]
  traceEntries  WorkflowTraceEntry[]
  traceEvents   WorkflowTraceEvent[]

  @@index([applicationId])
  @@index([name])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("workflows")
}

model WorkflowLaunch {
  id          String        @id @db.Uuid
  workflowId  String        @map("workflow_id") @db.Uuid
  status      String
  startedAt   DateTime      @default(now()) @map("started_at")
  completedAt DateTime?     @map("completed_at")
  workflow    Workflow      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  runs        WorkflowRun[]

  @@index([workflowId, startedAt])
  @@map("workflow_launches")
}

model WorkflowStage {
  id                    String               @id @db.Uuid
  workflowId            String               @map("workflow_id") @db.Uuid
  agentId               String               @map("agent_id") @db.Uuid
  label                 String
  ord                   Int
  objective             String?
  stageSystemPrompt     String?              @map("stage_system_prompt")
  taskPromptTemplate    String?              @map("task_prompt_template")
  allowedToolIds        Json?                @map("allowed_tool_ids")
  requiredEvidenceTypes Json?                @map("required_evidence_types")
  findingPolicy         Json?                @map("finding_policy")
  completionRule        Json?                @map("completion_rule")
  resultSchemaVersion   Int                  @default(1) @map("result_schema_version")
  handoffSchema         Json?                @map("handoff_schema")
  workflow              Workflow             @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  agent                 AiAgent              @relation(fields: [agentId], references: [id], onDelete: Restrict)
  traceEntries          WorkflowTraceEntry[]
  traceEvents           WorkflowTraceEvent[]

  @@unique([workflowId, ord])
  @@index([agentId])
  @@index([workflowId])
  @@map("workflow_stages")
}

model WorkflowRun {
  id               String               @id @db.Uuid
  workflowId       String               @map("workflow_id") @db.Uuid
  workflowLaunchId String               @map("workflow_launch_id") @db.Uuid
  targetId         String               @map("target_id") @db.Uuid
  executionKind    String               @default("workflow") @map("execution_kind")
  status           WorkflowRunStatus
  currentStepIndex Int                  @default(0) @map("current_step_index")
  startedAt        DateTime             @default(now()) @map("started_at")
  completedAt      DateTime?            @map("completed_at")
  workflow         Workflow             @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  launch           WorkflowLaunch       @relation(fields: [workflowLaunchId], references: [id], onDelete: Cascade)
  target           Application          @relation(fields: [targetId], references: [id], onDelete: Restrict)
  traceEntries     WorkflowTraceEntry[]
  traceEvents      WorkflowTraceEvent[]

  @@index([workflowLaunchId])
  @@index([workflowId])
  @@index([targetId])
  @@map("workflow_runs")
}

model WorkflowTraceEntry {
  id                  String                   @id @db.Uuid
  workflowRunId       String                   @map("workflow_run_id") @db.Uuid
  workflowId          String                   @map("workflow_id") @db.Uuid
  workflowStageId     String                   @map("workflow_stage_id") @db.Uuid
  stepIndex           Int                      @map("step_index")
  stageLabel          String                   @map("stage_label")
  agentId             String                   @map("agent_id") @db.Uuid
  agentName           String                   @map("agent_name")
  status              WorkflowTraceEntryStatus
  selectedToolIds     Json                     @map("selected_tool_ids")
  toolSelectionReason String                   @map("tool_selection_reason")
  targetSummary       String                   @map("target_summary")
  evidenceHighlights  Json                     @map("evidence_highlights")
  outputSummary       String                   @map("output_summary")
  createdAt           DateTime                 @default(now()) @map("created_at")
  workflowRun         WorkflowRun              @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  workflow            Workflow                 @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowStage       WorkflowStage            @relation(fields: [workflowStageId], references: [id], onDelete: Cascade)

  @@index([workflowRunId, stepIndex])
  @@index([workflowId])
  @@index([workflowStageId])
  @@map("workflow_trace_entries")
}

model WorkflowTraceEvent {
  id              String                   @id @db.Uuid
  workflowRunId   String                   @map("workflow_run_id") @db.Uuid
  workflowId      String                   @map("workflow_id") @db.Uuid
  workflowStageId String?                  @map("workflow_stage_id") @db.Uuid
  stepIndex       Int                      @map("step_index")
  ord             Int
  type            WorkflowTraceEventType
  status          WorkflowTraceEventStatus
  title           String
  summary         String
  detail          String?
  payload         Json
  createdAt       DateTime                 @default(now()) @map("created_at")
  workflowRun     WorkflowRun              @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  workflow        Workflow                 @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowStage   WorkflowStage?           @relation(fields: [workflowStageId], references: [id], onDelete: SetNull)

  @@index([workflowRunId, ord])
  @@index([workflowId])
  @@index([workflowStageId])
  @@map("workflow_trace_events")
}

model ExecutionReport {
  id                 String   @id @db.Uuid
  executionKind      String   @map("execution_kind")
  sourceExecutionId  String   @map("source_execution_id")
  sourceDefinitionId String?  @map("source_definition_id") @db.Uuid
  sourceStatus       String   @map("source_status")
  title              String
  targetLabel        String   @map("target_label")
  sourceLabel        String   @map("source_label")
  executiveSummary   String   @map("executive_summary")
  findingsCount      Int      @default(0) @map("findings_count")
  highestSeverity    String?  @map("highest_severity")
  findings           Json
  toolActivity       Json     @map("tool_activity")
  coverageOverview   Json     @map("coverage_overview")
  sourceSummary      Json     @map("source_summary")
  raw                Json
  generatedAt        DateTime @map("generated_at")
  archivedAt         DateTime? @map("archived_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([executionKind, sourceExecutionId])
  @@index([executionKind, sourceStatus])
  @@index([archivedAt, generatedAt(sort: Desc)])
  @@map("execution_reports")
}

model User {
  id            String    @id @db.Uuid
  email         String    @unique
  googleSubject String    @unique @map("google_subject")
  displayName   String?   @map("display_name")
  avatarUrl     String?   @map("avatar_url")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  sessions      Session[]

  @@map("users")
}

model Session {
  id               String    @id @db.Uuid
  sessionTokenHash String    @unique @map("session_token_hash")
  csrfToken        String    @map("csrf_token")
  userId           String    @map("user_id") @db.Uuid
  expiresAt        DateTime  @map("expires_at")
  lastSeenAt       DateTime  @default(now()) @map("last_seen_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model ScanRun {
  id               String              @id @db.Uuid
  mode             String              @default("legacy")
  applicationId    String?             @map("application_id") @db.Uuid
  agentId          String?             @map("agent_id") @db.Uuid
  scope            Json
  llmConfig        Json?               @map("llm_config")
  status           ScanRunStatus
  currentRound     Int                 @default(0) @map("current_round")
  tacticsTotal     Int                 @default(0) @map("tactics_total")
  tacticsComplete  Int                 @default(0) @map("tactics_complete")
  stopReason       String?             @map("stop_reason")
  summary          Json?
  createdAt        DateTime            @default(now()) @map("created_at")
  completedAt      DateTime?           @map("completed_at")
  scanTactics      ScanTactic[]
  scanFindings     ScanFinding[]
  scanAuditEntries ScanAuditEntry[]
  escalationRoutes EscalationRoute[]
  layerCoverage    ScanLayerCoverage[]
  assetNodes       ScanAssetNode[]
  assetEdges       ScanAssetEdge[]

  @@index([mode, createdAt])
  @@map("scan_runs")
}

model ScanAssetNode {
  id           String   @id
  scanRunId    String   @map("scan_run_id") @db.Uuid
  host         String
  type         String
  discoveredAt DateTime @map("discovered_at")
  metadata     Json
  scanRun      ScanRun  @relation(fields: [scanRunId], references: [id], onDelete: Cascade)

  @@index([scanRunId])
  @@index([scanRunId, host])
  @@map("scan_asset_nodes")
}

model ScanAssetEdge {
  id        String   @id
  scanRunId String   @map("scan_run_id") @db.Uuid
  fromNode  String   @map("from_node")
  toNode    String   @map("to_node")
  edgeType  String   @map("edge_type")
  evidence  String
  metadata  Json
  scanRun   ScanRun  @relation(fields: [scanRunId], references: [id], onDelete: Cascade)

  @@index([scanRunId])
  @@index([scanRunId, fromNode, toNode])
  @@map("scan_asset_edges")
}

model ScanTactic {
  id             String           @id @db.Uuid
  scanRunId      String           @map("scan_run_id") @db.Uuid
  target         String
  layer          String
  service        String?
  port           Int?
  riskScore      Float            @map("risk_score")
  status         ScanTacticStatus
  parentTacticId String?          @map("parent_tactic_id") @db.Uuid
  depth          Int
  createdAt      DateTime         @default(now()) @map("created_at")
  scanRun        ScanRun          @relation(fields: [scanRunId], references: [id], onDelete: Cascade)
  parentTactic   ScanTactic?      @relation("ScanTacticChildren", fields: [parentTacticId], references: [id], onDelete: SetNull)
  childTactics   ScanTactic[]     @relation("ScanTacticChildren")
  scanFindings   ScanFinding[]

  @@index([scanRunId])
  @@index([scanRunId, status, depth, riskScore(sort: Desc)])
  @@index([parentTacticId])
  @@map("scan_tactics")
}

model ScanFinding {
  id               String                   @id @db.Uuid
  scanRunId        String                   @map("scan_run_id") @db.Uuid
  scanTacticId     String                   @map("scan_tactic_id") @db.Uuid
  agentId          String                   @map("agent_id")
  primaryLayer     String?                  @map("primary_layer")
  relatedLayers    Json?                    @map("related_layers")
  category         String?
  target           Json?
  severity         String
  confidence       Float
  title            String
  description      String
  evidence         String
  evidenceItems    Json?                    @map("evidence_items")
  technique        String
  impact           String?
  recommendation   String?
  reproduceCommand String?                  @map("reproduce_command")
  reproduction     Json?
  validated        Boolean                  @default(false)
  validationStatus String?                  @map("validation_status")
  cwe              String?
  mitreId          String?                  @map("mitre_id")
  owasp            String?
  tags             Json?
  evidenceRefs     Json?                    @map("evidence_refs")
  sourceToolRuns   Json?                    @map("source_tool_runs")
  confidenceReason String?                  @map("confidence_reason")
  createdAt        DateTime                 @default(now()) @map("created_at")
  scanRun          ScanRun                  @relation(fields: [scanRunId], references: [id], onDelete: Cascade)
  scanTactic       ScanTactic               @relation(fields: [scanTacticId], references: [id], onDelete: Cascade)
  routeFindings    EscalationRouteFinding[]

  @@index([scanRunId])
  @@index([scanTacticId])
  @@index([scanRunId, severity])
  @@map("scan_findings")
}

model ScanLayerCoverage {
  scanRunId         String   @map("scan_run_id") @db.Uuid
  layer             String
  coverageStatus    String   @map("coverage_status")
  confidenceSummary String   @map("confidence_summary")
  toolRefs          Json     @map("tool_refs")
  evidenceRefs      Json     @map("evidence_refs")
  vulnerabilityIds  Json     @map("vulnerability_ids")
  gaps              Json
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")
  scanRun           ScanRun  @relation(fields: [scanRunId], references: [id], onDelete: Cascade)

  @@id([scanRunId, layer])
  @@index([scanRunId])
  @@map("scan_layer_coverage")
}

model ScanAuditEntry {
  id             String   @id @db.Uuid
  scanRunId      String   @map("scan_run_id") @db.Uuid
  timestamp      DateTime
  actor          String
  action         String
  targetTacticId String?  @map("target_tactic_id") @db.Uuid
  scopeValid     Boolean  @map("scope_valid")
  details        Json
  scanRun        ScanRun  @relation(fields: [scanRunId], references: [id], onDelete: Cascade)

  @@index([scanRunId, timestamp])
  @@map("scan_audit_entries")
}

model EscalationRoute {
  id            String                   @id @db.Uuid
  scanRunId     String                   @map("scan_run_id") @db.Uuid
  title         String
  compositeRisk Float                    @map("composite_risk")
  technique     String
  startTarget   String                   @map("start_target")
  endTarget     String                   @map("end_target")
  routeLength   Int                      @map("route_length")
  crossHost     Boolean                  @default(false) @map("cross_host")
  confidence    Float
  narrative     String?
  createdAt     DateTime                 @default(now()) @map("created_at")
  scanRun       ScanRun                  @relation(fields: [scanRunId], references: [id], onDelete: Cascade)
  routeFindings EscalationRouteFinding[]

  @@index([scanRunId, compositeRisk(sort: Desc)])
  @@map("escalation_routes")
}

model EscalationRouteFinding {
  escalationRouteId String          @map("escalation_route_id") @db.Uuid
  scanFindingId     String          @map("scan_finding_id") @db.Uuid
  ord               Int
  linkProbability   Float?          @map("link_probability")
  edgeType          String?         @map("edge_type")
  fromHost          String?         @map("from_host")
  toHost            String?         @map("to_host")
  escalationRoute   EscalationRoute @relation(fields: [escalationRouteId], references: [id], onDelete: Cascade)
  scanFinding       ScanFinding     @relation(fields: [scanFindingId], references: [id], onDelete: Cascade)

  @@id([escalationRouteId, scanFindingId, ord])
  @@index([scanFindingId])
  @@map("escalation_route_findings")
}
