+  summary: z.string().min(1),
+  reference: z.string().min(1).optional()
+});
+export type DefensiveEvidenceArtifact = z.infer<typeof defensiveEvidenceArtifactSchema>;
+
+export const defensiveResidualRiskSchema = z.object({
