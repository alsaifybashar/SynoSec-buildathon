+  summary: z.string().min(1),
+  checks: z.array(z.string().min(1)).min(1)
+});
+export type DefensiveVerification = z.infer<typeof defensiveVerificationSchema>;
+
+export const defensiveEvidenceArtifactSchema = z.object({
