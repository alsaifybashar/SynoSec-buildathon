+  return defensivePrioritizationSchema.parse({
+    modelVersion: "1.0",
+    summary: `${selectedSummary}${followUpSummary}`,
+    selectedAction,
+    rankedActions,
+    followUp,
+    weights: defensivePrioritizationWeights
