+  if (assetContext.internetExposed) {
+    exposure += 0.3;
+  }
+
+  if (assetContext.containsSensitiveData) {
+    exposure += 0.2;
+  }
+
+  if (/(public|internet|external|anonymous|admin|credential|production)/i.test(`${source.title} ${source.summary}`)) {
+    exposure += 0.1;
+  }
+
+  return clamp01(exposure);
