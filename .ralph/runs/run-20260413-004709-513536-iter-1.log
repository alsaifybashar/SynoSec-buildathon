+const normalizeSeverity = (severity: Severity): number => severityOrder[severity] / severityOrder.critical;
+
+const normalizeCriticality = (criticality: DefensiveAssetCriticality): number => {
+  switch (criticality) {
+    case "critical":
+      return 1;
+    case "high":
