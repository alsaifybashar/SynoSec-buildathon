+
+const normalizeCriticality = (criticality: DefensiveAssetCriticality): number => {
+  switch (criticality) {
+    case "critical":
+      return 1;
+    case "high":
+      return 0.85;
+    case "moderate":
+      return 0.6;
+    case "low":
+      return 0.35;
+  }
