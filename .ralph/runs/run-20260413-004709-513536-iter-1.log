+        || right.factorScores.confidence - left.factorScores.confidence
+        || left.candidateId.localeCompare(right.candidateId)
+      ))
+      .map((candidate, index, array) => ({
+        ...candidate,
+        decision: index === 0 ? "selected" : "not_selected",
