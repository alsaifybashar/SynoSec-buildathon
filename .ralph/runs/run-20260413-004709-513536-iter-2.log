+      summary: request.outcomeSummary,
+      checks: request.verificationPlan.checks
+    },
+    evidence: request.evidence,
+    residualRisk,
+    recommendedNextStep,
+    handoffSummary: `${request.change.summary} completed. ${recommendedNextStep.summary}`
+  });
