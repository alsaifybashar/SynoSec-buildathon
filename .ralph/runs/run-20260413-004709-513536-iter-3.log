+          evidenceRefs,
+          carryForward: true
+        });
+      }
+
+      return defensiveIssueOutcomeSchema.parse({
+        sourceId: source.id,
+        sourceKind: source.kind,
+        title: source.title,
+        severity: source.severity,
+        disposition: "skipped",
