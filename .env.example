# Shared app and Docker Compose ports
BACKEND_ENV=development
BACKEND_PORT=3001
POSTGRES_PORT=55432
DATABASE_URL=postgres://synosec:synosec@localhost:55432/synosec
VITE_DEV_PORT=5173
VITE_API_PROXY_TARGET=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# App auth
AUTH_ENABLED=false
AUTH_GOOGLE_ENABLED=true
AUTH_GOOGLE_CLIENT_ID=
AUTH_ALLOWED_EMAILS=
AUTH_SESSION_SECRET=replace-with-at-least-32-characters
AUTH_COOKIE_NAME=synosec_session
# Defaults to true when BACKEND_ENV or NODE_ENV is production. Keep false only for local HTTP development.
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_HOURS=168
AUTH_SESSION_TOUCH_INTERVAL_SECONDS=600

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
LLM_PROVIDER=anthropic
LOCAL_ENABLED=TRUE
LLM_LOCAL_BASE_URL=http://127.0.0.1:11434
LLM_LOCAL_API_PATH=/api/generate
LLM_LOCAL_MODEL=qwen3:1.7b
LLM_LOCAL_TIMEOUT_MS=15000
SCAN_COMMAND_TIMEOUT_MS=5000
SCAN_COMMAND_MAX_OUTPUT_BYTES=8192

# Scan limits
SCAN_MAX_DEPTH=3
SCAN_MAX_DURATION_MINUTES=10
SCAN_RATE_LIMIT_RPS=5

# Connector control plane
TOOL_EXECUTION_MODE=connector
CONNECTOR_SHARED_TOKEN=synosec-connector-dev
CONNECTOR_NAME=local-dev-connector
CONNECTOR_RUN_MODE=dry-run
CONNECTOR_ALLOWED_CAPABILITIES=passive,web-recon,network-recon,content-discovery,active-recon
CONNECTOR_CONTROL_PLANE_URL=http://localhost:3001
