# Shared app and Docker Compose ports
BACKEND_ENV=development
BACKEND_PORT=3001
POSTGRES_PORT=55432
DATABASE_URL=postgres://synosec:synosec@localhost:55432/synosec
VITE_DEV_PORT=5173
VITE_API_PROXY_TARGET=http://localhost:3001

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
LLM_PROVIDER=anthropic
LLM_LOCAL_BASE_URL=http://127.0.0.1:8010
LLM_LOCAL_API_PATH=/generate
LLM_LOCAL_MODEL=Qwen/Qwen3-1.7B
LLM_LOCAL_TIMEOUT_MS=15000

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=synosec-dev

# Scan limits
SCAN_MAX_DEPTH=3
SCAN_MAX_DURATION_MINUTES=10
SCAN_RATE_LIMIT_RPS=5
