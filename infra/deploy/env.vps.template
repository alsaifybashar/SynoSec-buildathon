# SynoSec VPS deploy defaults.
# The deploy workflow renders this template on the VPS, substitutes the
# host-specific public URL, and appends repo secrets as runtime-only values.

FRONTEND_URL=__FRONTEND_URL__
BACKEND_PUBLIC_PORT=3031
FRONTEND_PUBLIC_PORT=3030
CLAUDE_MODEL=claude-sonnet-4-6
LLM_PROVIDER=anthropic
SCAN_MAX_DEPTH=4
SCAN_MAX_DURATION_MINUTES=20
SCAN_RATE_LIMIT_RPS=5
AGENT_MAX_ITERATIONS=5
TOOL_EXECUTION_MODE=connector
CONNECTOR_NAME=vps-connector
CONNECTOR_VERSION=0.1.0
CONNECTOR_RUN_MODE=dry-run
CONNECTOR_POLL_INTERVAL_MS=1000
CONNECTOR_COMMAND_TIMEOUT_MS=30000
CONNECTOR_ALLOWED_CAPABILITIES=passive,web-recon,network-recon,content-discovery,active-recon
CONNECTOR_ALLOWED_SANDBOX_PROFILES=network-recon,read-only-parser,active-recon
CONNECTOR_ALLOWED_PRIVILEGE_PROFILES=read-only-network,active-network
AUTH_ENABLED=true
AUTH_GOOGLE_ENABLED=true
AUTH_GOOGLE_CLIENT_ID=__AUTH_GOOGLE_CLIENT_ID__
AUTH_COOKIE_NAME=synosec_session
AUTH_COOKIE_SECURE=true
AUTH_SESSION_TTL_HOURS=168
AUTH_SESSION_TOUCH_INTERVAL_SECONDS=600
